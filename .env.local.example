# Supabase Configuration (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role Key (required for user management API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Notification Provider (whatsapp | telegram | none)
NOTIFICATION_PROVIDER=none

# WhatsApp Business API (if NOTIFICATION_PROVIDER=whatsapp)
WHATSAPP_API_URL=https://graph.facebook.com/v17.0/YOUR_PHONE_ID/messages
WHATSAPP_API_TOKEN=your-whatsapp-token

# Telegram Bot API (if NOTIFICATION_PROVIDER=telegram)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
